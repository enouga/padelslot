# Reverse-proxy + HTTPS automatique (Let's Encrypt) pour Palova.
# Caddy résout les noms `frontend` / `backend` via le réseau interne Docker.

{
	email admin@palova.fr
	# Certificats « à la demande » pour les sous-domaines clubs : Caddy demande au backend
	# si le domaine est autorisé avant d'émettre un certificat.
	on_demand_tls {
		ask http://backend:3001/internal/tls-check
	}
}

# Plateforme (apex) → frontend. L'apex ne matche PAS le wildcard *.palova.fr,
# donc pas de chevauchement : certificat managé classique.
palova.fr {
	reverse_proxy frontend:3000
}

# API → backend. on_demand explicite : api.palova.fr matche aussi *.palova.fr,
# il faut une politique TLS COHÉRENTE avec le wildcard, sinon Caddy mélange
# « managé » et « on-demand » sur le même nom et refuse le handshake (alert 80).
api.palova.fr {
	tls {
		on_demand
	}
	reverse_proxy backend:3001
}

# www + sous-domaines clubs (<slug>.palova.fr) → frontend, certificat à la demande.
# www est volontairement retiré du bloc apex pour qu'il soit géré ici en on_demand
# (même résultat : il route vers le frontend) et n'entre plus en conflit.
*.palova.fr {
	tls {
		on_demand
	}
	reverse_proxy frontend:3000
}
